generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Candidate {
  id        String          @id @default(cuid())
  name      String
  email     String          @unique
  phone     String?
  position  String
  resumeUrl String?
  status    CandidateStatus @default(PENDING)
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt
}

enum CandidateStatus {
  PENDING
  PROCESSING
  PROCESSED
  REJECTED
}
